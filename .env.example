# Copy this file to .env and fill in the values, then source it before starting the server.
#
# Usage (bash/zsh):
#   cp .env.example .env
#   # edit .env with your actual keys
#   source .env
#   uvicorn src.api.server:app --port 8787 --reload
#
# Then open http://localhost:8787 in your browser.
# Enter ROADMAP_API_KEY in the chat panel ⚙ settings when prompted.

# Bearer token the browser sends to authenticate against the API endpoints.
# Set to any non-empty string; share it with anyone who needs to use the chat panel.
ROADMAP_API_KEY=change-me

# Anthropic API key — server-side only, never sent to the browser.
# Obtain from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
